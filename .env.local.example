# ── Email configuration for the contact form ──────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Your Gmail address
GMAIL_USER=theory.civil@gmail.com

# Gmail App Password (16 chars, NOT your regular password)
# Steps to generate:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search for "App Passwords" in Google Account settings
#   4. Generate a password for "Mail" → "Other (PdfOnlineStudio)"
#   5. Paste the 16-character password below (spaces are fine)
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
